{
  "name": "Vector Blockchain",
  "description": "UTXO L2 blockchain for AI agents — fast, safe, verifiable",
  "url": "https://apex-fusion.github.io/vector-ai-documentation/",
  "documentation": "https://apex-fusion.github.io/vector-ai-documentation/",
  "protocols": ["MCP", "A2A", "ACP"],
  "mcp_server": {
    "repository": "https://github.com/Apex-Fusion/mcp-server",
    "hosted_testnet": "https://mcp.vector.testnet.apexfusion.org/sse",
    "hosted_mainnet": "https://mcp.vector.mainnet.apexfusion.org/sse",
    "transport": "sse"
  },
  "sdk": {
    "python": {
      "repository": "https://github.com/Apex-Fusion/agent-sdk-py",
      "package": "apex-fusion-agent-sdk",
      "install": "pip install apex-fusion-agent-sdk",
      "base": "PyCardano"
    },
    "typescript": {
      "repository": "https://github.com/Apex-Fusion/agent-sdk-ts",
      "package": "@apexfusion/agent-sdk",
      "install": "npm install @apexfusion/agent-sdk",
      "base": "Lucid Evolution"
    }
  },
  "endpoints": {
    "testnet": {
      "ogmios": "wss://ogmios.vector.testnet.apexfusion.org",
      "submit": "https://submit.vector.testnet.apexfusion.org/api/submit/tx",
      "koios": "https://v2.koios.vector.testnet.apexfusion.org/",
      "explorer": "https://vector.testnet.apexscan.org"
    },
    "mainnet": {
      "ogmios": "wss://ogmios.vector.mainnet.apexfusion.org",
      "submit": "https://submit.vector.mainnet.apexfusion.org/api/submit/tx",
      "koios": "https://koios.vector.mainnet.apexfusion.org/",
      "explorer": "https://explorer.vector.mainnet.apexfusion.org"
    }
  },
  "capabilities": [
    "wallet_management",
    "token_transfers",
    "smart_contracts",
    "agent_registry",
    "agent_messaging",
    "spend_limits",
    "audit_logging",
    "dry_run"
  ],
  "chain": {
    "type": "UTXO",
    "consensus": "Ouroboros",
    "smart_contracts": "Plutus/Aiken",
    "finality": "~13 seconds (99.9%)",
    "throughput": "10x Cardano"
  }
}
